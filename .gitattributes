# Fallback: automatically normalize text files not listed below
* text=auto

# Source code
*.c      eol=lf
*.h      eol=lf

# Configuration files
*.yml    eol=lf
*.json   eol=lf
*.xml    eol=lf

# Script files
Makefile eol=lf

# Markdown and text
*.txt    eol=lf
*.md     eol=lf

# Binary files
*.png    binary